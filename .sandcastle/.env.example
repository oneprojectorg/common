# Anthropic API key
# If you want to use your Claude subscription instead of an API key, see https://github.com/mattpocock/sandcastle/issues/191
ANTHROPIC_API_KEY=
# Asana personal access token (https://app.asana.com/0/my-apps)
ASANA_PERSONAL_ACCESS_TOKEN=
# Asana project gid the agent reads from
ASANA_PROJECT_ID=
# Section gid — tasks the agent picks up from (Backlog)
ASANA_BACKLOG_SECTION_ID=
# Section gid — tasks moved here when the agent starts work
ASANA_IN_PROGRESS_SECTION_ID=
# Section gid — tasks moved here when the agent ships a PR
ASANA_IN_REVIEW_SECTION_ID=

# GitHub personal access token (https://github.com/settings/tokens)
# Required scopes: repo (push + create PR)
GH_TOKEN=

# Heartbeat poll interval (seconds) when the backlog has no matching tasks.
# The orchestrator hits Asana directly — no Claude tokens spent during idle.
# Set to 0 to disable heartbeat — the loop exits when the backlog is empty.
# Default: 120 (2 minutes).
HEARTBEAT_INTERVAL_SECONDS=30

# Maximum number of issues the planner may claim per iteration. Phase 2 runs
# these pipelines concurrently. Default: 2.
MAX_PARALLEL_ISSUES=2

# Branch new worktrees fork from, and the PR base for ship. Default: sandcastle
# (until the agent infrastructure lands on dev — then switch this to dev).
BASE_BRANCH=sandcastle
