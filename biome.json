{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "organizeImports": {
    "enabled": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all",
      "bracketSameLine": false,
      "arrowParentheses": "always"
    }
  },
  "linter": {
    "enabled": false
  },
  "css": {
    "formatter": {
      "enabled": false
    },
    "parser": {
      "cssModules": true
    }
  },
  "files": {
    "ignore": [
      ".next",
      "dist",
      "build",
      "node_modules",
      "pnpm-lock.yaml",
      "draco*.js",
      "*.md",
      "*.sql",
      "migrations/",
      "storybook-static",
      "playwright-report/",
      "test-results/",
      "playwright/.auth/",
      ".claude/",
      "*.css"
    ]
  }
}
