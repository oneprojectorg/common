{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Find",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Fetch",
      "Pnpm w:app lint"
    ],
    "deny": [
      "Pnpm build",
      "Pnpm w:db migrate",
      "Pnpm format"
    ],
    "ask": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-protected-branches.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/require-feature-branch.sh"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "allowWrite": ["."],
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.gnupg",
        ".env",
        ".env.local",
        ".env.docker",
        ".env.*"
      ]
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "api.github.com",
        "registry.npmjs.org",
        "*.npmjs.org",
        "registry.tiptap.dev",
        "*.anthropic.com",
        "docs.claude.com",
        "*.claude.com",
        "*.supabase.co",
        "*.supabase.com",
        "*.posthog.com",
        "api.posthog.com",
        "*.axiom.co",
        "mcp.axiom.co",
        "*.figma.com",
        "api.figma.com",
        "resend.com",
        "trpc.io",
        "zod.dev",
        "*.asana.com",
        "app.asana.com"
      ]
    },
    "excludedCommands": [
      "docker *",
      "docker-compose *",
      "supabase *"
    ],
    "allowUnsandboxedCommands": true,
    "failIfUnavailable": false
  }
}
