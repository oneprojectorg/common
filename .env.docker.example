# ── Supabase ─────────────────────────────────────────────────────────────────
# Public URL of the Supabase API. In Docker, this is the supabase service's
# exposed port on the host. Change to your hosted project URL in production.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321

# Server-side URL used within the Docker network (not exposed to the browser).
# Allows server components and API routes to reach Supabase via the Docker
# service name rather than going through the host port.
SUPABASE_URL=http://supabase:54321

# Supabase anon (public) key — safe to expose in the browser.
# Use the well-known local dev default for Docker, or copy from your hosted
# project's API settings page.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service-role key — server-side only, never expose to the browser.
# Use the well-known local dev default for Docker, or copy from your hosted
# project's API settings page.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT secret used to sign tokens. Must be at least 32 characters.
# The default value below matches the Supabase local dev default.
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# ── Redis ─────────────────────────────────────────────────────────────────────
# Connection URL for Redis. The service name `redis` resolves inside the Docker
# network; change to your hosted Redis URL in production.
REDIS_URL=redis://redis:6379

# ── App ───────────────────────────────────────────────────────────────────────
# Host port the Next.js app is exposed on. Override at startup:
#   APP_PORT=4000 docker compose up
# First two digits of all exposed ports. Suffix 00 = app, 01 = api.
# Override at startup: PORT_PREFIX=40 pnpm docker:dev  →  app:4000, api:4001
PORT_PREFIX=31

# SSR cookie encryption key — generate with:
# crypto.subtle.generateKey({name:"AES-CBC",length:256},true,["encrypt","decrypt"]).then(k=>crypto.subtle.exportKey("jwk",k)).then(JSON.stringify).then(console.log)
SSR_SECRETS_KEY={"alg":"A256CBC","ext":true,"k":"xUWFSEEnQPIlAkPqTxnIsZz5VRacNPEOzvG5ZBSJYN4","key_ops":["encrypt","decrypt"],"kty":"oct"}
