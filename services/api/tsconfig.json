{
  "extends": "@op/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.jsx",
    "./*.ts",
    "./*.tsx",
    "./*.js",
    "./*.jsx"
  ],
  "exclude": ["node_modules", "dist"]
}
